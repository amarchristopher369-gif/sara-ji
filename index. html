<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#2C1A2E">
<title>Christopher AI 💛</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   TOKENS
═══════════════════════════════════════ */
:root {
  --rose:    #C97B84;
  --rose2:   #B5606A;
  --gold:    #D4A853;
  --cream:   #FDF6EE;
  --deep:    #2C1A2E;
  --deep2:   #4A1F4E;
  --muted:   #7A6070;
  --light:   #EDE0D4;
  --white:   #FFFAF5;
  --tab-h:   64px;
  --hdr-h:   110px;
  --safe-b:  env(safe-area-inset-bottom, 0px);
}

/* ═══════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body { height: 100%; overflow: hidden; }
body {
  font-family: 'Inter', sans-serif;
  background: var(--cream);
  color: var(--deep);
  display: flex;
  flex-direction: column;
  max-width: 768px;
  margin: 0 auto;
  position: relative;
}

/* ═══════════════════════════════════════
   HEADER
═══════════════════════════════════════ */
.header {
  background: linear-gradient(160deg, var(--deep) 0%, var(--deep2) 100%);
  padding: 14px 20px 12px;
  text-align: center;
  flex-shrink: 0;
  box-shadow: 0 2px 20px rgba(44,26,46,0.35);
  z-index: 50;
}
.hdr-top { display: flex; align-items: center; justify-content: center; gap: 8px; }
.hdr-icon { font-size: 20px; }
.hdr-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--gold);
  letter-spacing: 1px;
}
.hdr-sub {
  font-size: 10px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 2.5px;
  text-transform: uppercase;
  margin-top: 1px;
}
.verse-banner {
  background: rgba(212,168,83,0.1);
  border: 1px solid rgba(212,168,83,0.22);
  border-radius: 8px;
  margin-top: 9px;
  padding: 7px 12px;
}
.verse-banner p {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 11.5px;
  color: rgba(255,255,255,0.72);
  line-height: 1.55;
}

/* ═══════════════════════════════════════
   APP BODY
═══════════════════════════════════════ */
.app-body {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ═══════════════════════════════════════
   SCREENS
═══════════════════════════════════════ */
.screen {
  position: absolute;
  inset: 0;
  bottom: calc(var(--tab-h) + var(--safe-b));
  display: flex;
  flex-direction: column;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.18s ease;
}
.screen.active {
  opacity: 1;
  pointer-events: all;
}

/* ═══════════════════════════════════════
   BOTTOM TAB BAR
═══════════════════════════════════════ */
.tabbar {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  height: calc(var(--tab-h) + var(--safe-b));
  padding-bottom: var(--safe-b);
  background: var(--white);
  border-top: 1px solid var(--light);
  display: flex;
  z-index: 100;
  box-shadow: 0 -2px 16px rgba(44,26,46,0.08);
}
.tab-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--muted);
  padding: 6px 4px 4px;
  transition: color 0.18s;
  position: relative;
}
.tab-btn .ti { font-size: 22px; line-height: 1; transition: transform 0.18s; }
.tab-btn .tl { font-size: 9.5px; font-weight: 500; letter-spacing: 0.4px; text-transform: uppercase; }
.tab-btn.active { color: var(--rose); }
.tab-btn.active .ti { transform: translateY(-1px); }
.tab-btn::before {
  content: '';
  position: absolute;
  top: 0; left: 20%; right: 20%;
  height: 2px;
  background: var(--rose);
  border-radius: 0 0 3px 3px;
  transform: scaleX(0);
  transition: transform 0.18s;
}
.tab-btn.active::before { transform: scaleX(1); }

/* ═══════════════════════════════════════
   CHAT SCREEN
═══════════════════════════════════════ */
#screen-chat { background: var(--cream); }

.chat-history-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 7px 14px;
  background: var(--white);
  border-bottom: 1px solid var(--light);
  flex-shrink: 0;
}
.chat-session-label {
  font-size: 11px;
  color: var(--muted);
  font-weight: 500;
}
.chat-history-btn {
  font-size: 11px;
  color: var(--rose);
  background: none;
  border: 1px solid rgba(201,123,132,0.3);
  border-radius: 20px;
  padding: 3px 10px;
  cursor: pointer;
  font-weight: 500;
  transition: background 0.15s;
}
.chat-history-btn:active { background: rgba(201,123,132,0.1); }

.chat-messages {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 14px 14px 8px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
}
.msg {
  display: flex;
  flex-direction: column;
  max-width: 82%;
}
.msg.ai  { align-self: flex-start; }
.msg.user { align-self: flex-end; }
.msg-meta {
  font-size: 9.5px;
  color: var(--muted);
  margin-bottom: 3px;
  padding: 0 5px;
  display: flex;
  align-items: center;
  gap: 5px;
}
.msg.user .msg-meta { justify-content: flex-end; }
.msg-time { opacity: 0.7; }
.msg-bubble {
  padding: 10px 14px;
  border-radius: 18px;
  font-size: 14px;
  line-height: 1.65;
  word-break: break-word;
}
.msg.ai .msg-bubble {
  background: var(--white);
  color: var(--deep);
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 8px rgba(44,26,46,0.07);
  border: 1px solid var(--light);
}
.msg.user .msg-bubble {
  background: linear-gradient(135deg, var(--rose), var(--rose2));
  color: #fff;
  border-bottom-right-radius: 4px;
}
.verse-chip {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 12.5px;
  color: var(--rose);
  border-left: 2px solid var(--gold);
  padding-left: 8px;
  margin-top: 7px;
  line-height: 1.5;
}

.day-divider {
  text-align: center;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
  position: relative;
  margin: 4px 0;
}
.day-divider span {
  background: var(--cream);
  padding: 0 10px;
  position: relative;
  z-index: 1;
}
.day-divider::before {
  content: '';
  position: absolute;
  top: 50%; left: 0; right: 0;
  height: 1px;
  background: var(--light);
}

.typing-wrap {
  padding: 0 14px 6px;
  flex-shrink: 0;
}
.typing-dots {
  display: none;
  background: var(--white);
  border: 1px solid var(--light);
  border-radius: 18px;
  border-bottom-left-radius: 4px;
  padding: 11px 15px;
  width: fit-content;
  gap: 4px;
  align-items: center;
  box-shadow: 0 1px 6px rgba(44,26,46,0.07);
}
.typing-dots.show { display: flex; }
.dot { width: 7px; height: 7px; background: var(--rose); border-radius: 50%; animation: bop 1.2s infinite; }
.dot:nth-child(2) { animation-delay:.2s; }
.dot:nth-child(3) { animation-delay:.4s; }
@keyframes bop { 0%,80%,100%{transform:translateY(0);opacity:.4} 40%{transform:translateY(-6px);opacity:1} }

.chat-input-area {
  flex-shrink: 0;
  background: var(--white);
  border-top: 1px solid var(--light);
  padding: 10px 12px;
  display: flex;
  gap: 8px;
  align-items: flex-end;
}
#chatInput {
  flex: 1;
  border: 1.5px solid var(--light);
  border-radius: 22px;
  padding: 10px 16px;
  font-size: 14.5px;
  font-family: 'Inter', sans-serif;
  outline: none;
  resize: none;
  max-height: 110px;
  background: var(--cream);
  color: var(--deep);
  transition: border-color 0.2s;
  line-height: 1.5;
}
#chatInput:focus { border-color: var(--rose); }
#chatInput::placeholder { color: var(--muted); }
.send-btn {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--rose), var(--rose2));
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  flex-shrink: 0;
  transition: transform 0.15s, opacity 0.15s;
  box-shadow: 0 2px 10px rgba(201,123,132,0.4);
}
.send-btn:active { transform: scale(0.9); }
.send-btn:disabled { opacity: 0.45; cursor: default; box-shadow: none; }

/* History modal */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(44,26,46,0.55);
  z-index: 200;
  align-items: flex-end;
  justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal-sheet {
  background: var(--white);
  border-radius: 20px 20px 0 0;
  width: 100%;
  max-width: 768px;
  max-height: 72vh;
  display: flex;
  flex-direction: column;
  padding: 0 0 calc(16px + var(--safe-b));
  animation: slideUp 0.22s ease;
}
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.modal-handle {
  width: 40px; height: 4px;
  background: var(--light);
  border-radius: 2px;
  margin: 12px auto 0;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px 10px;
  border-bottom: 1px solid var(--light);
}
.modal-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 19px;
  font-weight: 600;
  color: var(--deep);
}
.modal-close {
  font-size: 22px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--muted);
  padding: 2px 6px;
}
.history-list {
  overflow-y: auto;
  padding: 10px 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  -webkit-overflow-scrolling: touch;
}
.history-item {
  background: var(--cream);
  border: 1px solid var(--light);
  border-radius: 12px;
  padding: 11px 14px;
  cursor: pointer;
  transition: background 0.15s;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.history-item:active { background: rgba(201,123,132,0.08); }
.history-item-left { flex: 1; min-width: 0; }
.history-item-date {
  font-size: 10px;
  color: var(--rose);
  font-weight: 500;
  letter-spacing: 0.5px;
  margin-bottom: 3px;
}
.history-item-preview {
  font-size: 13px;
  color: var(--deep);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.history-item-count {
  font-size: 11px;
  color: var(--muted);
  background: var(--light);
  border-radius: 10px;
  padding: 2px 8px;
  flex-shrink: 0;
}
.history-empty {
  text-align: center;
  padding: 30px 20px;
  color: var(--muted);
  font-size: 14px;
}
.history-actions {
  display: flex;
  gap: 8px;
  padding: 8px 14px 4px;
  border-top: 1px solid var(--light);
}
.hist-act-btn {
  flex: 1;
  padding: 10px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  border: none;
  font-family: 'Inter', sans-serif;
  transition: opacity 0.15s;
}
.hist-act-btn:active { opacity: 0.75; }
.hist-new { background: linear-gradient(135deg, var(--rose), var(--rose2)); color: #fff; }
.hist-clear { background: var(--light); color: var(--deep); }

/* ═══════════════════════════════════════
   GROW (DEVOTIONAL) SCREEN
═══════════════════════════════════════ */
#screen-devotional {
  background: var(--cream);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.grow-scroll { padding: 14px; display: flex; flex-direction: column; gap: 14px; }

.dev-card {
  background: var(--white);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 14px rgba(44,26,46,0.07);
  border: 1px solid var(--light);
}
.dev-card-hdr {
  background: linear-gradient(135deg, var(--deep), var(--deep2));
  padding: 13px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.dev-card-hdr .hicon { font-size: 20px; }
.dev-card-hdr h3 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-weight: 600;
  color: var(--gold);
}
.dev-body { padding: 14px 16px; }
.dev-verse {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 15.5px;
  line-height: 1.7;
  color: var(--deep);
  margin-bottom: 8px;
}
.dev-ref { font-size: 11.5px; color: var(--rose); font-weight: 500; letter-spacing: 0.5px; margin-bottom: 11px; }
.dev-reflection { font-size: 13.5px; line-height: 1.7; color: #4A3A4E; }
.dev-btn {
  width: 100%;
  margin-top: 12px;
  padding: 12px;
  background: linear-gradient(135deg, var(--rose), var(--rose2));
  color: #fff;
  border: none;
  border-radius: 10px;
  font-size: 13.5px;
  font-weight: 500;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: opacity 0.15s;
}
.dev-btn:active { opacity: 0.82; }

.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--deep);
  padding: 0 2px;
}
.section-sub { font-size: 11.5px; color: var(--muted); padding: 0 2px; margin-top: -10px; }

.quality-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.q-card {
  background: var(--white);
  border: 1px solid var(--light);
  border-radius: 14px;
  padding: 15px 12px;
  text-align: center;
  cursor: pointer;
  transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  box-shadow: 0 1px 6px rgba(44,26,46,0.05);
}
.q-card:active { transform: scale(0.96); border-color: var(--rose); box-shadow: 0 3px 14px rgba(201,123,132,0.2); }
.q-icon { font-size: 26px; margin-bottom: 6px; }
.q-name { font-family: 'Cormorant Garamond', serif; font-size: 15px; font-weight: 600; color: var(--deep); margin-bottom: 3px; }
.q-ref  { font-size: 10px; color: var(--muted); }

/* ═══════════════════════════════════════
   PRAYER SCREEN
═══════════════════════════════════════ */
#screen-prayer {
  background: var(--cream);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.prayer-scroll { padding: 14px; display: flex; flex-direction: column; gap: 14px; }

.prayer-hero {
  background: linear-gradient(135deg, var(--deep), var(--deep2));
  border-radius: 16px;
  padding: 22px 20px;
  text-align: center;
}
.prayer-hero h2 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  color: var(--gold);
  margin-bottom: 6px;
}
.prayer-hero p { font-size: 12px; color: rgba(255,255,255,0.58); line-height: 1.6; }

.prayer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.p-btn {
  background: var(--white);
  border: 1.5px solid var(--light);
  border-radius: 14px;
  padding: 15px 10px;
  text-align: center;
  cursor: pointer;
  transition: all 0.18s;
  font-family: 'Inter', sans-serif;
}
.p-btn:active, .p-btn.sel {
  border-color: var(--rose);
  background: rgba(201,123,132,0.06);
  box-shadow: 0 2px 12px rgba(201,123,132,0.18);
}
.p-icon { font-size: 24px; margin-bottom: 5px; }
.p-label { font-size: 12px; font-weight: 500; color: var(--deep); }

.prayer-result {
  background: var(--white);
  border-radius: 16px;
  padding: 18px;
  border: 1px solid var(--light);
  box-shadow: 0 2px 12px rgba(44,26,46,0.07);
  display: none;
}
.prayer-result.show { display: block; }
.prayer-result h4 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  color: var(--rose);
  margin-bottom: 12px;
}
.prayer-body {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 15px;
  line-height: 1.9;
  color: var(--deep);
}
.prayer-copy-btn {
  margin-top: 14px;
  width: 100%;
  padding: 10px;
  background: var(--light);
  border: none;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  color: var(--deep);
  font-family: 'Inter', sans-serif;
  transition: background 0.15s;
}
.prayer-copy-btn:active { background: rgba(212,168,83,0.25); }

/* ═══════════════════════════════════════
   ABOUT SCREEN
═══════════════════════════════════════ */
#screen-about {
  background: var(--cream);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.about-scroll {
  padding: 20px 18px calc(16px + var(--safe-b));
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.about-heart { font-size: 56px; animation: hb 2.2s ease-in-out infinite; }
@keyframes hb { 0%,100%{transform:scale(1)} 14%{transform:scale(1.16)} 28%{transform:scale(1)} 42%{transform:scale(1.1)} 56%{transform:scale(1)} }
.about-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 30px;
  font-weight: 600;
  color: var(--deep);
  text-align: center;
  line-height: 1.2;
}
.about-desc { font-size: 13px; color: var(--muted); text-align: center; line-height: 1.65; }

.love-card {
  width: 100%;
  background: linear-gradient(135deg, #FDF0F2, #FDF6EE);
  border: 1px solid rgba(201,123,132,0.28);
  border-radius: 16px;
  padding: 20px;
}
.love-card p {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 15.5px;
  line-height: 1.85;
  color: var(--deep);
  text-align: center;
}
.love-card .sig {
  margin-top: 12px;
  font-size: 13.5px;
  color: var(--rose);
  font-weight: 500;
  text-align: right;
  font-style: normal;
}

.anchor-verse {
  width: 100%;
  background: var(--deep);
  border-radius: 16px;
  padding: 20px;
  text-align: center;
}
.anchor-verse p {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 14.5px;
  color: rgba(255,255,255,0.84);
  line-height: 1.85;
}
.anchor-verse .ref { margin-top: 10px; font-size: 11.5px; color: var(--gold); letter-spacing: 1.2px; font-style: normal; }

.feat-list { width: 100%; display: flex; flex-direction: column; gap: 8px; }
.feat-item {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--white);
  border-radius: 12px;
  padding: 12px 14px;
  border: 1px solid var(--light);
  font-size: 13.5px;
  color: var(--deep);
}
.feat-item .fi { font-size: 20px; }

/* ═══════════════════════════════════════
   LOADING OVERLAY
═══════════════════════════════════════ */
.loader-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(44,26,46,0.48);
  z-index: 300;
  align-items: center;
  justify-content: center;
}
.loader-overlay.show { display: flex; }
.loader-box {
  background: var(--white);
  border-radius: 20px;
  padding: 28px 44px;
  text-align: center;
  box-shadow: 0 8px 40px rgba(44,26,46,0.3);
}
.spinner {
  width: 36px; height: 36px;
  border: 3px solid var(--light);
  border-top-color: var(--rose);
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
  margin: 0 auto 12px;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loader-box p { font-family: 'Cormorant Garamond', serif; font-size: 16px; color: var(--deep); }

/* ═══════════════════════════════════════
   TOAST
═══════════════════════════════════════ */
.toast {
  position: fixed;
  bottom: calc(var(--tab-h) + var(--safe-b) + 14px);
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--deep);
  color: #fff;
  font-size: 13px;
  padding: 9px 18px;
  border-radius: 30px;
  opacity: 0;
  transition: opacity 0.25s, transform 0.25s;
  z-index: 400;
  white-space: nowrap;
  pointer-events: none;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

